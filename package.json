{
    "name": "nestjs-starter",
    "version": "1.0.0",
    "description": "Production-ready NestJS boilerplate with JWT auth, PostgreSQL/Prisma, AWS S3/SES, Bull/Redis queues, Docker/K8s support, and MCP integration for AI capabilities",
    "author": "hmake98",
    "license": "MIT",
    "private": true,
    "engines": {
        "node": ">=20.0.0",
        "yarn": ">=1.22.0"
    },
    "scripts": {
        "prepare": "husky",
        "postinstall": "prisma generate",
        "prebuild": "rimraf dist",
        "pretest": "prisma generate",
        "build": "nest build",
        "start": "node dist/main",
        "dev": "nest start --watch",
        "debug": "nest start --debug --watch",
        "update:package": "npx npm-check-updates -u",
        "prisma:generate": "prisma generate",
        "prisma:migrate": "prisma migrate dev",
        "prisma:migrate-prod": "prisma migrate deploy",
        "prisma:studio": "prisma studio",
        "make-badges": "istanbul-badges-readme",
        "seed:email": "nestjs-command seed:emails",
        "rollback:email": "nestjs-command rollback:emails",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "test": "jest --config test/jest.json --coverage --runInBand --passWithNoTests --forceExit",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --config test/jest.json --runInBand"
    },
    "dependencies": {
        "@aws-sdk/client-s3": "^3.994.0",
        "@aws-sdk/client-ses": "^3.994.0",
        "@aws-sdk/s3-request-presigner": "^3.994.0",
        "@faker-js/faker": "^10.3.0",
        "@hmake98/nest-mcp": "^1.0.7",
        "@nestjs/bull": "^11.0.4",
        "@nestjs/common": "^11.1.14",
        "@nestjs/config": "^4.0.3",
        "@nestjs/core": "^11.1.14",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.1.14",
        "@nestjs/schedule": "^6.1.1",
        "@nestjs/swagger": "^11.2.6",
        "@nestjs/terminus": "^11.1.1",
        "@nestjs/throttler": "^6.5.0",
        "@prisma/client": "6.19.0",
        "@sentry/node": "^10.39.0",
        "@sentry/tracing": "^7.120.4",
        "@types/express": "^5.0.6",
        "argon2": "^0.44.0",
        "bull": "^4.16.5",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.3",
        "compression": "^1.8.1",
        "date-fns": "^4.1.0",
        "dotenv": "^17.3.1",
        "handlebars": "^4.7.8",
        "helmet": "^8.1.0",
        "jsonwebtoken": "^9.0.3",
        "lodash": "^4.17.23",
        "nestjs-command": "^3.1.5",
        "nestjs-i18n": "^10.6.0",
        "nestjs-pino": "^4.6.0",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "passport-local": "^1.0.0",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "pino-pretty": "^13.1.3",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.2",
        "swagger-ui-express": "^5.0.1"
    },
    "devDependencies": {
        "@commitlint/cli": "^20.4.2",
        "@commitlint/config-conventional": "^20.4.2",
        "@nestjs/cli": "^11.0.16",
        "@nestjs/testing": "^11.1.14",
        "@swc/cli": "^0.8.0",
        "@swc/core": "^1.15.11",
        "@swc/jest": "^0.2.39",
        "@types/bull": "^4.10.4",
        "@types/compression": "^1.8.1",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/lodash": "^4.17.23",
        "@types/node": "^25.3.0",
        "@types/passport": "^1.0.17",
        "@types/passport-jwt": "^4.0.1",
        "@types/passport-local": "^1.0.38",
        "@types/supertest": "^6.0.3",
        "@types/swagger-ui-express": "^4.1.8",
        "@types/ws": "^8.18.1",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "cross-env": "^10.1.0",
        "dotenv-cli": "^11.0.0",
        "eslint": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-import-resolver-typescript": "^4.4.4",
        "eslint-plugin-import": "^2.32.0",
        "eslint-plugin-jest": "^29.15.0",
        "eslint-plugin-prettier": "^5.5.5",
        "eslint-plugin-promise": "^7.2.1",
        "husky": "^9.1.7",
        "istanbul-badges-readme": "^1.9.0",
        "jest": "^30.2.0",
        "lint-staged": "^16.2.7",
        "prettier": "^3.8.1",
        "prisma": "6.19.0",
        "rimraf": "^6.1.3",
        "supertest": "^7.2.2",
        "ts-jest": "^29.4.6",
        "ts-loader": "^9.5.4",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "5.9.3",
        "typescript-eslint": "^8.56.0",
        "ws": "^8.19.0"
    },
    "lint-staged": {
        "{src,test}/**/*.{ts,js,json}": [
            "prettier --write",
            "eslint --fix"
        ]
    },
    "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e"
}
